{
  "name": "alien-editor",
  "version": "0.1.0",
  "description": "A Vue 3 block-based rich text editor with Tailwind CSS integration",
  "type": "module",
  "main": "./dist/alien-editor.umd.cjs",
  "module": "./dist/alien-editor.js",
  "exports": {
    ".": {
      "import": "./dist/alien-editor.js",
      "require": "./dist/alien-editor.umd.cjs"
    },
    "./nuxt": {
      "import": "./dist/nuxt.js",
      "require": "./dist/nuxt.cjs"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:nuxt": "vite build --config vite.nuxt.config.ts",
    "type-check": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "editor",
    "rich-text",
    "block-editor",
    "tailwind",
    "nuxt"
  ],
  "license": "MIT"
}
